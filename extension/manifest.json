{
  "manifest_version": 3,
  "name": "Aegis Authenticator",
  "short_name": "Aegis",
  "version": "0.4.0",
  "description": "Zero-knowledge TOTP autofill from your Aegis vault.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Aegis",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms",
    "tabs"
  ],
  "host_permissions": [],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "commands": {
    "fill-otp": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Aegis: autofill matched OTP into the focused field"
    },
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "mac": "Command+Shift+A"
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "__APP_ORIGIN__/*",
        "__APP_PREVIEW_ORIGIN__/*",
        "http://localhost:8080/*"
      ],
      "js": ["announce.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "externally_connectable": {
    "matches": [
      "__APP_ORIGIN__/*",
      "__APP_PREVIEW_ORIGIN__/*",
      "http://localhost:8080/*"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' __SUPABASE_ORIGIN__ https://api.pwnedpasswords.com; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; base-uri 'none'; frame-ancestors 'none';"
  },
  "web_accessible_resources": [],
  "minimum_chrome_version": "110"
}
