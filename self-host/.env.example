# Copy to `.env` and fill in real values before `docker compose up -d`.
# See docs/self-host.md for how to generate each value.

# Postgres superuser password. Any strong random string.
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# HS256 signing secret shared by PostgREST and GoTrue. 32+ random bytes.
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret

# Public URL of the Aegis web client. Used by GoTrue for email redirects.
SITE_URL=http://localhost:5173

# JWTs signed with JWT_SECRET. Mint them with the helper in
# docs/self-host.md (`node self-host/scripts/mint-keys.mjs`).
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
